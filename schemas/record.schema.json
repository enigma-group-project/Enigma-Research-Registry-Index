{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DatasetProof (off-chain record.json) — Enigma-Research-Registry-Index",
  "type": "object",
  "required": ["datasetId", "version", "datasetCid", "owner"],
  "properties": {
    "datasetId":   { "type": "string", "description": "natural key; hashed to the on-chain id" },
    "title":       { "type": "string" },
    "version":     { "type": "string", "description": "semantic version of the dataset" },
    "datasetCid":  { "type": "string", "description": "IPFS CID of the dataset archive" },
    "owner":       { "type": "string", "pattern": "^0x[0-9a-fA-F]{40}$" },
    "anchoredAt":  { "type": "string", "format": "date-time" },
    "doi":         { "type": "string" }
  }
}
